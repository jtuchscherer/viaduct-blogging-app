# User type representing authenticated users
type User implements Node {
  id: ID!
  username: String!
  email: String!
  name: String!
  isAdmin: Boolean! @resolver
  posts: [Post!]! @resolver
  createdAt: String!
}

# Post type for blog posts
type Post implements Node {
  id: ID!
  title: String!
  content: String!
  author: User! @resolver
  comments: [Comment!]! @resolver
  commentCount: Int! @resolver
  likes: [Like!]! @resolver
  likeCount: Int! @resolver
  isLikedByMe: Boolean! @resolver
  createdAt: String!
  updatedAt: String!
}

# Comment type for post comments
type Comment implements Node {
  id: ID!
  content: String!
  author: User! @resolver
  post: Post! @resolver
  createdAt: String!
}

# Like type for post likes
type Like implements Node {
  id: ID!
  user: User! @resolver
  post: Post! @resolver
  createdAt: String!
}

# Input types for mutations
input CreatePostInput {
  title: String!
  content: String!
}

input UpdatePostInput {
  id: ID! @idOf(type: "Post")
  title: String
  content: String
}

input CreateCommentInput {
  postId: ID! @idOf(type: "Post")
  content: String!
}

# Relay-style cursor pagination types
type PostsConnection @connection {
  edges: [PostEdge]
  pageInfo: PageInfo!
  totalCount: Int
}

type PostEdge @edge {
  node: Post
  cursor: String!
}

# Admin types
type AdminStats {
  userCount: Int!
  postCount: Int!
  commentCount: Int!
  likeCount: Int!
}

type UserContentCounts {
  postCount: Int!
  commentCount: Int!
  likeCount: Int!
}

type AdminDeleteUserResult {
  success: Boolean!
  postsDeleted: Int!
  commentsDeleted: Int!
  likesDeleted: Int!
}

input AdminUpdateUserInput {
  id: ID! @idOf(type: "User")
  name: String
  email: String
  isAdmin: Boolean
}

input AdminUpdatePostInput {
  id: ID! @idOf(type: "Post")
  title: String
  content: String
}

# Extend the Query type for read operations
extend type Query {
  # Get all posts (public)
  posts: [Post!]! @resolver

  # Get a single post by ID (public)
  post(id: ID! @idOf(type: "Post")): Post @resolver

  # Get current user's posts (requires auth)
  myPosts: [Post!]! @resolver

  # Get current authenticated user
  me: User @resolver

  # Get comments for a specific post
  postComments(postId: ID! @idOf(type: "Post")): [Comment!]! @resolver

  # Relay-style cursor pagination for posts (public)
  postsConnection(first: Int, after: String): PostsConnection @resolver

  # Admin queries (require admin role)
  adminStats: AdminStats! @resolver
  adminUsers: [User!]! @resolver
  adminUser(id: ID! @idOf(type: "User")): User @resolver
  adminUserContentCounts(userId: ID! @idOf(type: "User")): UserContentCounts! @resolver
  adminPosts: [Post!]! @resolver
  adminPost(id: ID! @idOf(type: "Post")): Post @resolver
  adminComments: [Comment!]! @resolver
}

# Extend mutations for write operations
extend type Mutation {
  # Post operations
  createPost(input: CreatePostInput!): Post! @resolver
  updatePost(input: UpdatePostInput!): Post! @resolver
  deletePost(id: ID! @idOf(type: "Post")): Boolean! @resolver

  # Comment operations
  createComment(input: CreateCommentInput!): Comment! @resolver
  deleteComment(id: ID! @idOf(type: "Comment")): Boolean! @resolver

  # Like operations
  likePost(postId: ID! @idOf(type: "Post")): Like! @resolver
  unlikePost(postId: ID! @idOf(type: "Post")): Boolean! @resolver

  # Admin mutations (require admin role)
  adminUpdateUser(input: AdminUpdateUserInput!): User! @resolver
  adminDeleteUser(id: ID! @idOf(type: "User")): AdminDeleteUserResult! @resolver
  adminUpdatePost(input: AdminUpdatePostInput!): Post! @resolver
  adminDeletePost(id: ID! @idOf(type: "Post")): Boolean! @resolver
  adminDeleteComment(id: ID! @idOf(type: "Comment")): Boolean! @resolver
}
